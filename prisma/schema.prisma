generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ModuleType {
  CORE
  BONUS
}

enum ActivityType {
  LOGIN
  LOGOUT
  LISTEN_COMPLETE
  QUIZ_SUBMIT
}

enum LearningReleaseStatus {
  DRAFT
  REVIEW_READY
  PUBLISHED
  ARCHIVED
}

enum AudioAssetStatus {
  PENDING
  GENERATED
  FAILED
}

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique
  passwordHash          String
  firstName             String
  lastName              String
  company               String?
  companyId             String?
  role                  UserRole            @default(USER)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  companyRef            Company?            @relation("CompanyUsers", fields: [companyId], references: [id], onDelete: SetNull)
  quizAttempts          QuizAttempt[]
  listenEvents          ListenEvent[]
  activityLogs          ActivityLog[]
  createdReleases       LearningRelease[]   @relation("ReleaseCreatedBy")
  adminActionsPerformed AdminActionLog[]    @relation("AdminActionActor")
  learnerEnrollments    LearnerEnrollment[]
  learnerModuleProgress LearnerModuleProgress[]

  @@index([companyId])
}

model QuizAttempt {
  id        String           @id @default(cuid())
  userId    String
  audioSlug String
  releaseId String?
  moduleId  String?
  score     Int
  total     Int
  passed    Boolean
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  release   LearningRelease? @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  module    LearningModule?  @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([audioSlug])
  @@index([userId, releaseId])
}

model Company {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  users        User[]            @relation("CompanyUsers")
  releases     LearningRelease[]
  adminActions AdminActionLog[]

  @@index([isActive])
}

model LearningRelease {
  id                 String                @id @default(cuid())
  companyId          String
  version            Int
  status             LearningReleaseStatus @default(DRAFT)
  createdById        String?
  publishedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  company            Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy          User?                 @relation("ReleaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  modules            LearningModule[]
  learnerEnrollments LearnerEnrollment[]
  learnerProgress    LearnerModuleProgress[]
  listenEvents       ListenEvent[]
  quizAttempts       QuizAttempt[]

  @@unique([companyId, version])
  @@index([companyId, status])
}

model LearningModule {
  id              String                 @id @default(cuid())
  releaseId       String
  partKey         String
  chapterKey      String
  contentKey      String
  title           String
  orderIndex      Int
  moduleType      ModuleType             @default(CORE)
  scriptText      String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  release         LearningRelease        @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  quizQuestions   LearningQuizQuestion[]
  audioAsset    AudioAsset?
  learnerProgress LearnerModuleProgress[]
  listenEvents  ListenEvent[]
  quizAttempts  QuizAttempt[]

  @@unique([releaseId, contentKey])
  @@index([releaseId, orderIndex])
}

model LearningQuizQuestion {
  id          String         @id @default(cuid())
  moduleId    String
  orderIndex  Int
  question    String
  options     Json
  answerIndex Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  module      LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, orderIndex])
  @@index([moduleId])
}

model AudioAsset {
  id              String           @id @default(cuid())
  moduleId        String           @unique
  blobPath        String
  durationSec     Int?
  provider        String
  providerVoiceId String
  status          AudioAssetStatus @default(PENDING)
  errorMessage    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  module          LearningModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model LearnerEnrollment {
  id         String          @id @default(cuid())
  userId     String
  releaseId  String
  assignedAt DateTime        @default(now())
  isActive   Boolean         @default(true)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  release    LearningRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([userId, releaseId])
  @@index([userId, isActive])
  @@index([releaseId, isActive])
}

model AdminActionLog {
  id          String   @id @default(cuid())
  actorUserId String
  companyId   String?
  actionType  String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation("AdminActionActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([companyId, createdAt])
  @@index([actionType])
}

model LearnerModuleProgress {
  id               String          @id @default(cuid())
  userId           String
  releaseId        String
  moduleId         String
  listenPercentMax Int             @default(0)
  lastListenedAt   DateTime?
  completedAt      DateTime?
  quizBestScore    Int?
  quizBestTotal    Int?
  quizPassed       Boolean         @default(false)
  quizPassedAt     DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  release          LearningRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  module           LearningModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, releaseId, moduleId])
  @@index([userId, releaseId])
  @@index([releaseId, moduleId])
}

model ListenEvent {
  id          String           @id @default(cuid())
  userId      String
  audioSlug   String
  releaseId   String?
  moduleId    String?
  completedAt DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  release     LearningRelease? @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  module      LearningModule?  @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  @@unique([userId, audioSlug])
  @@index([audioSlug])
  @@index([userId, releaseId])
}

model ActivityLog {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  audioSlug String?
  score     Int?
  total     Int?
  passed    Boolean?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
